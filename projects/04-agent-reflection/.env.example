# ============================================================
# 04-agent-reflection 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入真实值

# OpenAI API 配置
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Reflexion 配置
MAX_TRIALS=3          # 最大反思轮数（1=无反思，只跑一次）
MAX_STEPS=10          # 内层 ReAct 每轮最大步数

# 评估器模式
# ground_truth : 程序比对标准答案（需要预定义答案，确定性高）
# llm_judge    : LLM 评估答案质量（无需标准答案，但需额外 API 调用）
EVALUATOR_MODE=ground_truth

# 日志级别
LOG_LEVEL=INFO
