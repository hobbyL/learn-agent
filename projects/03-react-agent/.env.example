# OpenAI API 密钥
OPENAI_API_KEY=sk-your-key-here

# API 基础地址（如果使用代理或兼容服务，取消注释并修改）
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型选择（默认 gpt-4o-mini）
OPENAI_MODEL=gpt-4o-mini

# Agent 模式切换：react（ReAct 推理链） / direct（直接工具调用，对照组）
AGENT_MODE=react

# 日志级别：DEBUG 显示完整 API 交互，INFO 只显示推理链
LOG_LEVEL=INFO

# ReAct 最大推理步数（防止死循环）
MAX_STEPS=10
