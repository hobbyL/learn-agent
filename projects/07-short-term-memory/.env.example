# OpenAI API 配置（必填）
OPENAI_API_KEY=your-api-key-here

# 模型名称（可选，默认 gpt-4o-mini）
# MODEL_NAME=gpt-4o-mini

# 可选：使用自定义 API 端点（兼容 OpenAI 接口的代理服务）
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# 默认记忆策略（用于无参数启动时的交互模式）
# 可选值：baseline / sliding / token / summary
MEMORY_STRATEGY=summary

# 滑动窗口策略：保留最近 N 轮
SLIDING_WINDOW_TURNS=6

# Token 限额策略 / 摘要策略：最大 token 数
TOKEN_LIMIT=3000

# 摘要策略：触发压缩的阈值（当前 token 数 > TOKEN_LIMIT * 此比例时压缩）
SUMMARY_THRESHOLD_RATIO=0.7
