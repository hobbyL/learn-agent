# 环境变量配置示例
# 使用方式：
#   cp .env.example .env
#   编辑 .env 文件，填入你的真实 API Key
#   注意：.env 文件已加入 .gitignore，不会被提交到代码仓库

# ============================================================
# OpenAI API 配置（必填）
# ============================================================

# OpenAI API Key（必填）
# 获取方式：https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API Base URL（可选）
# 默认使用官方地址，如需使用第三方兼容 API 或代理，修改此项
# 例如：Azure OpenAI、国内代理服务等
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================
# 模型配置
# ============================================================

# 使用的模型名称（可选，默认为 gpt-4o-mini）
# 常用选项：
#   gpt-4o-mini     — 速度快，成本低，适合学习和测试
#   gpt-4o          — 更强的推理能力
#   gpt-3.5-turbo   — 旧版模型，成本最低
MODEL_NAME=gpt-4o-mini

# ============================================================
# 工具 API 配置
# ============================================================

# OpenWeatherMap API Key（查询天气工具必填）
# 获取方式：
#   1. 访问 https://openweathermap.org/api
#   2. 免费注册账号
#   3. 在 API Keys 页面创建 Key
#   免费版限制：每分钟 60 次，每月 100 万次
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# ============================================================
# 日志配置（可选）
# ============================================================

# 日志级别（可选）
# DEBUG：显示所有细节（工具参数、API 响应等）
# INFO：只显示关键步骤（默认）
# OFF：静默模式
LOG_LEVEL=INFO
