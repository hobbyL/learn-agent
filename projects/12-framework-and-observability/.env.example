# .env.example —— 复制为 .env 并填入实际值

# OpenAI 或兼容端点
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1   # 自定义端点（可选，默认 OpenAI 官方）
OPENAI_MODEL=gpt-4o-mini                    # 默认模型

# LangSmith tracing（可选，不设置时程序正常运行）
# 注册地址：https://smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=12-framework-and-observability
