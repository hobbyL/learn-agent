# OpenAI API 配置
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1  # 可选，兼容 OpenAI API 的服务

# 模型配置
MODEL_NAME=gpt-4o-mini

# 规划运行参数（均为可选，不填用代码默认值）
MAX_REPLANS=3          # 最大局部重规划次数，避免无限循环
MAX_STEPS=8            # 内层 ReAct 每个子任务的最大工具调用步数
ENABLE_EXPANSION=false # 是否启用动态展开判断（开启会额外消耗 token）

# 可复现性（可选）
RANDOM_SEED=42         # 固定采集/环境事件的随机性，便于复现 demo 结果
