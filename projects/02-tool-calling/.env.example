# 环境变量配置示例
# 使用方式：
#   cp .env.example .env
#   编辑 .env 文件，填入你的真实 API Key
#   注意：.env 文件已加入 .gitignore，不会被提交到代码仓库

# ============================================================
# OpenAI API 配置（必填）
# ============================================================

# OpenAI API Key（必填）
# 获取方式：https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API Base URL（可选）
# 默认使用官方地址，如需使用第三方兼容 API 或代理，修改此项
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================
# 模型配置
# ============================================================

# 使用的模型名称（可选，默认为 gpt-4o-mini）
MODEL_NAME=gpt-4o-mini

# ============================================================
# 日志配置（可选）
# ============================================================

# 日志级别（可选）
# DEBUG：显示所有细节（工具参数、Schema、校验过程等）
# INFO：只显示关键步骤（默认）
# OFF：静默模式
LOG_LEVEL=INFO

# 注意：02 的 8 个工具全部是本地计算，不依赖任何外部 API，
#       因此不需要 OpenWeatherMap 之类的第三方 Key。
